# Patterns excluded from `railway up` uploads.
# Backend lives at the repo root (api/, src/, models/, requirements.txt).
# Goal: keep upload <50 MB. The full Home Credit CSVs (>1.7 GB) and frontend
# build artifacts must not ship to Railway.

# ---------- Frontend (Vercel deploys this, not Railway) ------------------
frontend/

# ---------- Build / dev tooling ------------------------------------------
.git/
.github/
.vscode/
.idea/
.claude/
.railway/
.deepeval/
notebooks/
tests/

# ---------- Python caches & virtualenvs ----------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/
myenv/

# ---------- Secrets ------------------------------------------------------
.env
.env.*
!.env.example

# ---------- Data: keep only the runtime sample ---------------------------
# Exclude everything in /data EXCEPT processed/features_sample.csv (20 MB),
# which src/data_loader.py reads on startup.
/data/*
!/data/processed/
/data/processed/*
!/data/processed/features_sample.csv

