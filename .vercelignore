# repo root and never accidentally exclude frontend/src, etc.
/api/
/src/
/models/
/data/
/notebooks/
/tests/
/__pycache__/
/requirements.txt
/railway.json
/bank_logs.xlsx
/image.png
*.pyc
*.ipynb
*.log
